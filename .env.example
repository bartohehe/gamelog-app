IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=
RIOT_API_KEY=
STEAM_API_KEY=
# TMDB API key — zarejestruj na https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Feature flags
# Set to true to enable the corresponding feature. False disables the feature and hides related UI elements.
AUTH_ENABLED=true
MULTIPLAYER_ENABLED=true
SOCIAL_FEATURES_ENABLED=true
REVIEWS_ENABLED=true
BACKLOG_ENABLED=true
STATISTICS_ENABLED=true
TRANSLATION_ENABLED=true
ADVANCED_RATING_ENABLED=false
MEDIA_ENABLED=true

# Database password (change before exposing to the internet)
DB_PASSWORD=

# JWT signing secret (change before exposing to the internet)
JWT_SECRET=

# Nginx reverse proxy — set DOMAIN for automatic Let's Encrypt SSL
# Leave DOMAIN empty for HTTP-only mode (local/LAN use)
DOMAIN=
SSL_EMAIL=

# ASP.NET Core environment (Development or Production)
ASPNETCORE_ENVIRONMENT=Development